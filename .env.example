# ===========================================
# Instituto UP - Painel Administrativo
# ===========================================
# Copie este arquivo para .env.local e preencha os valores.
# cp .env.example .env.local

# Connection string do PostgreSQL
DATABASE_URL=postgres://usuario:senha@host:5432/banco

# Habilitar SSL na conexao com o banco (true para provedores como Aiven, Neon, Vercel Postgres)
PG_SSL=true

# Token de autenticacao do painel (compartilhado entre usuarios)
DASHBOARD_TOKEN=seu_token_seguro_aqui

# Segredo dedicado para assinar o cookie de sessao
# Use um valor longo, aleatorio e diferente do DASHBOARD_TOKEN
DASHBOARD_SESSION_SECRET=gere_um_segredo_longo_e_unico

# Configuracao de treinamentos ativos (JSON)
# Exemplo: [{"id":"2026-03-01","label":"Turma Marco 2026","startsAt":"2026-03-01T09:00:00Z"}]
TRAINING_CONFIG=[]
